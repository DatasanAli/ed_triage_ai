# AWS — use a named profile, never store keys directly
# Set up with: aws configure --profile ed-triage
AWS_PROFILE=ed-triage
AWS_REGION=us-east-1

# Pinecone — API key is stored in AWS Secrets Manager, not here
# Secret name: prod/pinecone/api_key
# Retrieved automatically at runtime via boto3
PINECONE_INDEX_NAME=ed-triage-cases
S3_BUCKET=ed-triage-capstone-group7
